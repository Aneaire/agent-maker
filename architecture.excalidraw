      "locked": false,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "Tool action completes\n  → emits event to agentEvents\n  → processAutomation matches rules\n  → executes chained actions\n\nAction Types:\n  DB-only:   create_note, create_task,\n             update_task, store_memory\n  Job-based: run_prompt (creates job)\n  HTTP:      send_email, fire_webhook\n  Agent:     trigger_agent\n\nSupports {{event.field}} templates\nSchedules + Timers run natively",
      "lineHeight": 1.25
    },

